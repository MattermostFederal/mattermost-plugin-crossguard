{
    "id": "crossguard",
    "name": "Cross Guard",
    "description": "Cross Guard plugin for Mattermost Federal.",
    "homepage_url": "https://github.com/MattermostFederal/mattermost-plugin-crossguard",
    "support_url": "https://github.com/MattermostFederal/mattermost-plugin-crossguard/issues",
    "min_server_version": "6.2.1",
    "server": {
        "executables": {
            "linux-amd64": "server/dist/plugin-linux-amd64",
            "linux-arm64": "server/dist/plugin-linux-arm64"
        }
    },
    "webapp": {
        "bundle_path": "webapp/dist/main.js"
    },
    "settings_schema": {
        "header": "Cross-domain message relay for Mattermost Federal. [View full documentation](/plugins/crossguard/public/help/help.html).",
        "footer": "",
        "settings": [],
        "sections": [
{
                "key": "NATSConfiguration",
                "title": "NATS Configuration",
                "settings": [
                    {
                        "key": "InboundConnections",
                        "display_name": "Inbound Connections (NATS -> Mattermost)",
                        "type": "custom",
                        "default": "[]"
                    },
                    {
                        "key": "OutboundConnections",
                        "display_name": "Outbound Connections (Mattermost -> NATS)",
                        "type": "custom",
                        "default": "[]"
                    }
                ]
            },
            {
                "key": "RelaySettings",
                "title": "Relay Settings",
                "settings": [
                    {
                        "key": "UsernameLookup",
                        "display_name": "Username Lookup",
                        "type": "bool",
                        "default": true,
                        "help_text": "When enabled, inbound messages will be posted as the matching local user if a user with the same username exists. When disabled, a synthetic relay user is always created."
                    },
                    {
                        "key": "RestrictToSystemAdmins",
                        "display_name": "Restrict Connection Management to System Admins",
                        "type": "bool",
                        "default": false,
                        "help_text": "When enabled, only system admins can link or unlink connections to teams and channels. When disabled, team admins can manage team connections and channel admins can manage channel connections."
                    }
                ]
            }
        ]
    }
}
